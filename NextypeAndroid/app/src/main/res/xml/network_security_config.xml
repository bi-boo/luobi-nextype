<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- 明确禁止明文 HTTP 流量（所有连接必须使用 HTTPS/WSS） -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
