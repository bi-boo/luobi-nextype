<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- 顶部导航栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/toolbar_height"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="16dp"
        android:background="@color/background"
        android:gravity="center_vertical">

        <!-- 返回按钮 -->
        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_back"
            android:scaleType="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="返回" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="设置"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginStart="4dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/page_padding">

            <!-- ========== 惯用手设置 ========== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="@dimen/spacing_lg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="惯用手"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="12dp" />

                <!-- 分段选择器 -->
                <RadioGroup
                    android:id="@+id/handModeRadioGroup"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_segment_container"
                    android:padding="4dp">

                    <RadioButton
                        android:id="@+id/radioLeftHand"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="左手"
                        android:textSize="14sp"
                        android:textColor="@color/segment_text_color"
                        android:button="@null"
                        android:gravity="center"
                        android:background="@drawable/bg_segment_item" />

                    <RadioButton
                        android:id="@+id/radioRightHand"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="右手"
                        android:textSize="14sp"
                        android:textColor="@color/segment_text_color"
                        android:button="@null"
                        android:gravity="center"
                        android:background="@drawable/bg_segment_item" />

                </RadioGroup>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="发送按钮会放在你方便点击的一侧"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

            <!-- ========== 字号设置 ========== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="@dimen/spacing_lg"
                android:layout_marginTop="@dimen/spacing_md">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="输入框字号"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="8dp" />

                <!-- 预览文字 -->
                <TextView
                    android:id="@+id/fontSizePreview"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="把这个按钮调大一点"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"
                    android:gravity="center" />

                <!-- 字号滑动条 -->
                <com.google.android.material.slider.Slider
                    android:id="@+id/fontSizeSlider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="0"
                    android:valueTo="4"
                    android:stepSize="1"
                    android:value="1"
                    app:tickVisible="false"
                    app:labelBehavior="gone"
                    app:trackColorActive="@color/md_theme_primary"
                    app:trackColorInactive="@color/md_theme_surfaceVariant"
                    app:thumbColor="@color/md_theme_primary"
                    app:haloColor="@color/md_theme_primaryContainer" />

                <!-- 档位标签 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp">

                    <TextView
                        android:id="@+id/fontLabel0"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="小"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/fontLabel1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="标准"
                        android:textSize="12sp"
                        android:textColor="@color/accent"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/fontLabel2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="中"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/fontLabel3"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="大"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/fontLabel4"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="特大"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        android:gravity="center" />

                </LinearLayout>
            </LinearLayout>

            <!-- ========== 剪贴板设置 ========== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:layout_marginTop="@dimen/spacing_md">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="插入时同步到剪贴板"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchPasteClipboard"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginStart="16dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="发送时同步到剪贴板"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchPasteEnterClipboard"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
            </LinearLayout>

            <!-- 说明文字 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="开启后，内容会同步复制到手机剪贴板"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="8dp"
                android:layout_marginStart="4dp" />

            <!-- ========== 屏幕常亮 & 自动变暗设置 ========== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:layout_marginTop="@dimen/spacing_xxl">

                <!-- 保持屏幕常亮 主开关 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="保持屏幕常亮"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchKeepScreenOn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <!-- 自动变暗子设置容器 -->
                <LinearLayout
                    android:id="@+id/autoDimSettingsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginStart="16dp" />

                    <!-- 闲置自动变暗 子开关 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="闲置自动变暗"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary" />

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switchAutoDim"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginStart="16dp" />

                    <!-- 变暗等待时间 选择行 -->
                    <LinearLayout
                        android:id="@+id/autoDimTimeoutRow"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:gravity="center_vertical"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="变暗等待时间"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:id="@+id/autoDimTimeoutValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="30 秒"
                            android:textSize="14sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginEnd="4dp" />

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_back"
                            android:rotation="180"
                            android:alpha="0.5"
                            android:contentDescription="@null"
                            android:importantForAccessibility="no" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- 说明文字 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="开启后应用将保持屏幕常亮，闲置一段时间后自动变暗以节省电量"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="8dp"
                android:layout_marginStart="4dp" />

            <!-- ========== 辅助功能设置 ========== -->
            <LinearLayout
                android:id="@+id/accessibilityButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_card"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center_vertical"
                android:layout_marginTop="@dimen/spacing_xxl"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="辅助功能"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/accessibilityStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="检测中..."
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginEnd="4dp" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_back"
                    android:rotation="180"
                    android:alpha="0.5"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="用于执行电脑端发来的模拟点击指令"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="8dp"
                android:layout_marginStart="4dp" />

            <!-- ========== 使用说明入口 ========== -->
            <LinearLayout
                android:id="@+id/aboutButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_card"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center_vertical"
                android:layout_marginTop="@dimen/spacing_xxl"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="使用说明"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_back"
                    android:rotation="180"
                    android:alpha="0.5"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no" />
            </LinearLayout>

            <!-- ========== 隐私政策入口 ========== -->
            <LinearLayout
                android:id="@+id/privacyPolicyButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_card"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center_vertical"
                android:layout_marginTop="@dimen/spacing_md"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="隐私政策"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_back"
                    android:rotation="180"
                    android:alpha="0.5"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
