<?xml version="1.0" encoding="utf-8"?>
<!-- Material Design 3 风格的设备列表项 - 左右结构布局 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_card"
    android:paddingStart="16dp"
    android:paddingEnd="8dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp"
    android:layout_marginBottom="8dp"
    android:gravity="center_vertical">

    <!-- 左侧：设备图标 -->
    <ImageView
        android:id="@+id/deviceIcon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_device_laptop"
        android:scaleType="center"
        android:background="@drawable/bg_icon_circle"
        android:padding="8dp"
        app:tint="@color/accent"
        android:contentDescription="@null"
        android:importantForAccessibility="no" />

    <!-- 中间：设备信息 (名称 + 配对日期) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp">

        <TextView
            android:id="@+id/deviceNameText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="设备名称"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:ellipsize="end"
            android:maxLines="1" />

        <TextView
            android:id="@+id/devicePairedDateText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="配对于 2024/01/01"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- 右侧：按钮区域 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- 编辑按钮 -->
        <Button
            android:id="@+id/editButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:minWidth="56dp"
            android:text="编辑"
            android:textColor="@color/accent"
            android:textSize="14sp"
            android:textAllCaps="false"
            android:background="@drawable/bg_text_button_ripple"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />

        <!-- 解除配对按钮 -->
        <Button
            android:id="@+id/unpairButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:minWidth="56dp"
            android:text="解除"
            android:textColor="@color/danger"
            android:textSize="14sp"
            android:textAllCaps="false"
            android:background="@drawable/bg_text_button_ripple"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />
    </LinearLayout>

</LinearLayout>
