<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:paddingStart="@dimen/spacing_xxl"
    android:paddingEnd="@dimen/spacing_xxl"
    android:paddingTop="48dp"
    android:paddingBottom="32dp">

    <!-- 上方弹性空间 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- ========== 中央区域：Logo + 标题 + 配对按钮 ========== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Logo -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="80dp"
            android:layout_height="80dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@mipmap/ic_launcher"
                android:scaleType="centerCrop"
                android:contentDescription="APP Logo" />

        </com.google.android.material.card.MaterialCardView>

        <!-- 副标题 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="欢迎使用 落笔 Nextype"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="24dp" />

        <!-- 主标题 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="连接电脑，开启高效输入体验"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginTop="8dp" />

        <!-- 配对电脑按钮 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/addDeviceButton"
            android:layout_width="220dp"
            android:layout_height="56dp"
            android:text="配对电脑"
            android:textSize="17sp"
            android:textColor="@color/white"
            android:layout_marginTop="40dp"
            style="@style/Widget.NextypeAndroid.Button.Primary"
            app:backgroundTint="@color/primary"
            app:cornerRadius="@dimen/radius_pill"
            app:elevation="2dp"
            app:rippleColor="#33FFFFFF"
            app:icon="@drawable/ic_device"
            app:iconGravity="textStart"
            app:iconTint="@color/white"
            app:iconSize="20dp"
            app:iconPadding="8dp" />

    </LinearLayout>

    <!-- 中间弹性空间 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- ========== 下部区域：获取电脑端应用卡片 ========== -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="@dimen/radius_container"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:cardBackgroundColor="@color/card_background">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="28dp"
            android:paddingBottom="28dp"
            android:paddingStart="@dimen/spacing_xl"
            android:paddingEnd="@dimen/spacing_xl">

            <!-- 说明文字 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="在浏览器打开以下网址，下载电脑端应用"
                android:textSize="13sp"
                android:textColor="@color/hint" />

            <!-- 地址栏样式的域名框 -->
            <LinearLayout
                android:id="@+id/copyUrlLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_url_bar"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:clickable="true"
                android:focusable="true">

                <!-- 地球图标 -->
                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_web"
                    app:tint="@color/hint"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no" />

                <!-- 域名 -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="yuanfengai.cn"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:layout_marginStart="10dp" />

                <!-- 复制按钮 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="复制"
                    android:textSize="13sp"
                    android:textColor="@color/primary"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- ========== 底部：使用场景 + 稍后配对 ========== -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp">

        <TextView
            android:id="@+id/scenarioButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="使用场景 >"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground" />

        <TextView
            android:id="@+id/skipButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="稍后配对 >"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground" />

    </LinearLayout>

</LinearLayout>
