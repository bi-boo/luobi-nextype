<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_paper">

    <!-- 顶部导航栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/toolbar_height"
        android:orientation="horizontal"
        android:paddingStart="@dimen/spacing_lg"
        android:paddingEnd="4dp"
        android:background="@android:color/transparent"
        android:elevation="0dp"
        android:gravity="center_vertical">

        <!-- 品牌名称 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:baselineAligned="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="落笔"
                android:textSize="20sp"
                android:textColor="@color/icon_default"
                android:fontFamily="sans-serif"
                android:letterSpacing="0.02" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nextype"
                android:textSize="20sp"
                android:textColor="@color/icon_default"
                android:fontFamily="sans-serif"
                android:layout_marginStart="6dp"
                android:letterSpacing="-0.01" />
        </LinearLayout>

        <!-- 设备状态和设置按钮 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- 设备状态标签：显示设备名称和图标，点击可切换设备 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/deviceStatusCard"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                app:cardBackgroundColor="@color/divider"
                app:cardCornerRadius="@dimen/radius_status_chip"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:paddingStart="10dp"
                    android:paddingEnd="12dp"
                    android:gravity="center_vertical">

                    <!-- 连接状态小绿点 -->
                    <View
                        android:id="@+id/deviceStatusDot"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/bg_status_dot"
                        android:visibility="gone" />

                    <!-- 设备图标 -->
                    <ImageView
                        android:id="@+id/deviceStatusIcon"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_marginStart="6dp"
                        android:src="@drawable/ic_device_laptop"
                        android:contentDescription="@null"
                        android:importantForAccessibility="no" />

                    <!-- 设备名称 -->
                    <TextView
                        android:id="@+id/deviceStatusName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="未连接"
                        android:textSize="13sp"
                        android:textColor="@color/text_primary"
                        android:maxWidth="80dp"
                        android:ellipsize="end"
                        android:singleLine="true"
                        android:layout_marginStart="6dp" />

                    <!-- 下拉箭头（多设备时显示） -->
                    <ImageView
                        android:id="@+id/deviceStatusArrow"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_chevron_down"
                        android:layout_marginStart="2dp"
                        android:visibility="gone"
                        android:contentDescription="@null"
                        android:importantForAccessibility="no" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 菜单按钮（汉堡图标） -->
            <ImageButton
                android:id="@+id/settingsButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_menu"
                android:scaleType="center"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="菜单" />
        </LinearLayout>
    </LinearLayout>

    <!-- 输入区域容器 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:focusable="true"
        android:focusableInTouchMode="true">

        <!-- 输入框 - 占满剩余空间 -->
        <com.nextype.android.WakeUpEditText
            android:id="@+id/inputEditText"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:paddingStart="@dimen/spacing_lg"
            android:paddingEnd="@dimen/spacing_lg"
            android:paddingTop="@dimen/spacing_sm"
            android:paddingBottom="@dimen/spacing_sm"
            android:gravity="top|start"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:inputType="textMultiLine|textCapSentences"
            android:scrollbars="vertical"
            android:lineSpacingMultiplier="1.3" />

        <!-- 上滑预览文本 -->
        <TextView
            android:id="@+id/swipePreviewText"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:paddingStart="@dimen/spacing_lg"
            android:paddingEnd="@dimen/spacing_lg"
            android:paddingTop="@dimen/spacing_sm"
            android:paddingBottom="@dimen/spacing_sm"
            android:gravity="top|start"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:lineSpacingMultiplier="1.3"
            android:visibility="gone" />
    </FrameLayout>

    <!-- 底部按钮区域 -->
    <LinearLayout
        android:id="@+id/buttonsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="@dimen/spacing_lg"
        android:paddingEnd="@dimen/spacing_lg"
        android:paddingTop="@dimen/spacing_lg"
        android:paddingBottom="@dimen/spacing_sm"
        android:background="@android:color/transparent"
        android:gravity="center">

        <!-- 清空按钮 - 实心白色+描边 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/clearButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="清空"
            android:textSize="14sp"
            android:textColor="@color/selector_btn_action_content"
            android:singleLine="true"
            android:minWidth="0dp"
            android:paddingStart="8dp"
            android:paddingEnd="12dp"
            style="@style/Widget.Material3.Button"
            app:backgroundTint="@color/selector_btn_action_bg"
            app:strokeColor="@color/selector_btn_stroke"
            app:strokeWidth="@dimen/border_width"
            app:cornerRadius="@dimen/radius_pill"
            app:elevation="0dp"
            app:rippleColor="@android:color/transparent"
            android:layout_marginEnd="@dimen/spacing_sm"
            android:fontFamily="sans-serif-medium"
            app:icon="@drawable/ic_clear"
            app:iconGravity="textStart"
            app:iconTint="@color/selector_btn_action_content"
            app:iconSize="18dp"
            app:iconPadding="4dp" />

        <!-- 同步按钮 - 实心白色+描边 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/syncButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="插入"
            android:textSize="14sp"
            android:textColor="@color/selector_btn_action_content"
            android:singleLine="true"
            android:minWidth="0dp"
            android:paddingStart="8dp"
            android:paddingEnd="12dp"
            style="@style/Widget.Material3.Button"
            app:backgroundTint="@color/selector_btn_action_bg"
            app:strokeColor="@color/selector_btn_stroke"
            app:strokeWidth="@dimen/border_width"
            app:cornerRadius="@dimen/radius_pill"
            app:elevation="0dp"
            app:rippleColor="@android:color/transparent"
            android:layout_marginEnd="@dimen/spacing_sm"
            android:fontFamily="sans-serif-medium"
            app:icon="@drawable/ic_input"
            app:iconGravity="textStart"
            app:iconTint="@color/selector_btn_action_content"
            app:iconSize="18dp"
            app:iconPadding="4dp" />

        <!-- 发送按钮 - 蓝色填充，回车图标在右 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/sendButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="发送"
            android:textSize="14sp"
            android:textColor="@color/selector_btn_send_content"
            android:singleLine="true"
            android:minWidth="0dp"
            android:paddingStart="12dp"
            android:paddingEnd="8dp"
            style="@style/Widget.Material3.Button"
            app:backgroundTint="@color/selector_btn_send_bg"
            app:strokeColor="@color/selector_btn_send_stroke"
            app:strokeWidth="@dimen/border_width"
            app:cornerRadius="@dimen/radius_pill"
            app:elevation="0dp"
            app:rippleColor="@android:color/transparent"
            android:fontFamily="sans-serif-medium"
            app:icon="@drawable/ic_enter"
            app:iconGravity="textEnd"
            app:iconTint="@color/selector_btn_send_content"
            app:iconSize="18dp"
            app:iconPadding="4dp" />
    </LinearLayout>


</LinearLayout>
