<?xml version="1.0" encoding="utf-8"?>
<!-- Material Design 风格设备编辑弹窗 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingBottom="24dp">

    <!-- 标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="8dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="编辑设备"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <ImageButton
            android:id="@+id/closeButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="关闭"
            app:tint="@color/text_secondary" />
    </LinearLayout>

    <!-- 图标选择区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="设备图标"
            android:textSize="14sp"
            android:textColor="@color/icon_default"
            android:layout_marginBottom="12dp" />

        <!-- 图标选择网格 -->
        <LinearLayout
            android:id="@+id/iconGridContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- 笔记本 MacBook -->
            <FrameLayout
                android:id="@+id/iconLaptop"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginEnd="32dp"
                android:background="@drawable/bg_icon_selector"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_device_laptop"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no" />
            </FrameLayout>

            <!-- 台式机 iMac -->
            <FrameLayout
                android:id="@+id/iconDesktop"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginEnd="32dp"
                android:background="@drawable/bg_icon_selector"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_device_desktop"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no" />
            </FrameLayout>

            <!-- 工作站显示器 -->
            <FrameLayout
                android:id="@+id/iconMonitor"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/bg_icon_selector"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_device_monitor"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no" />
            </FrameLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- 名称输入区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="设备别名"
            android:textSize="14sp"
            android:textColor="@color/icon_default"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/editDeviceName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:maxLines="1"
            android:maxLength="16"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/hint"
            android:hint="输入自定义名称"
            android:padding="14dp"
            android:background="@drawable/bg_edit_text_outline" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="最多8个汉字或16个字符"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- 按钮区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="24dp"
        android:gravity="end">

        <!-- 取消按钮 -->
        <TextView
            android:id="@+id/cancelButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="取消"
            android:textSize="15sp"
            android:textColor="@color/icon_default"
            android:gravity="center"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:layout_marginEnd="12dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true" />

        <!-- 保存按钮 -->
        <TextView
            android:id="@+id/saveButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="保存"
            android:textSize="15sp"
            android:textColor="@android:color/white"
            android:gravity="center"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:background="@drawable/bg_primary_button"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

</LinearLayout>
